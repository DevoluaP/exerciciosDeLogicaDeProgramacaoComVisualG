Algoritmo "calculo-area-circulo"
// Disciplina  : [Lógica de Programaçăo com Visualg]
// Professor   : Jailson Costa dos Santos
// Descriçăo   : Calcula a área de um círculo.
// Autor(a)    : Paulo Henrique Moreira Araujo
// Data atual  : 28/03/2026

Var
raio, area: real

Inicio
escreva("Digite o raio: ")
leia(raio)
area <- 3.14 * raio * raio
escreva("Área do circulo: ", area)

Fimalgoritmo